"""
生产环境配置文件
复制此文件为 .env 并填写实际配置
"""

# 应用配置
APP_NAME="悬赏任务平台"
APP_VERSION="3.0.0"
DEBUG=False

# 数据库配置（推荐使用PostgreSQL）
DATABASE_URL="sqlite:///./reward_task.db"

# PostgreSQL 配置示例（生产环境推荐）
# DATABASE_URL="postgresql://username:password@localhost:5432/reward_task"

# JWT配置（必须修改为强密钥）
SECRET_KEY="your-super-secret-key-change-this-in-production"

# API前缀
API_PREFIX="/api"

# CORS配置（填写实际域名）
ALLOWED_ORIGINS=["https://your-domain.com"]

# Token过期时间
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
