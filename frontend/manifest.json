{
	"name": "reward-task-platform",
	"appid": "__UNI__REWARDTASK",
	"description": "悬赏任务平台 - 安全可靠的悬赏任务交易平台",
	"versionName": "3.0.0",
	"versionCode": "300",
	"transformPx": false,
	"app-plus": {
		"usingComponents": true,
		"nvueStyleCompiler": "uni-app",
		"compilerVersion": 3,
		"splashscreen": {
			"alwaysShowBeforeRender": true,
			"waiting": true,
			"autoclose": true,
			"delay": 0
		},
		"modules": {
			"Payment": true,
			"Camera": true
		},
		"distribute": {
			"android": {
				"permissions": [
					"<uses-permission android:name=\"android.permission.INTERNET\"/>",
					"<uses-permission android:name=\"android.permission.ACCESS_NETWORK_STATE\"/>",
					"<uses-permission android:name=\"android.permission.ACCESS_WIFI_STATE\"/>",
					"<uses-permission android:name=\"android.permission.READ_PHONE_STATE\"/>",
					"<uses-permission android:name=\"android.permission.WRITE_SETTINGS\"/>",
					"<uses-permission android:name=\"android.permission.CAMERA\"/>",
					"<uses-permission android:name=\"android.permission.READ_EXTERNAL_STORAGE\"/>",
					"<uses-permission android:name=\"android.permission.WRITE_EXTERNAL_STORAGE\"/>"
				],
				"abiFilters": ["armeabi-v7a", "arm64-v8a"],
				"minSdkVersion": 21,
				"targetSdkVersion": 30
			},
			"ios": {
				"dSYMs": false,
				"idfa": false
			},
			"sdkConfigs": {
				"payment": {
					"weixin": {
						"appid": "",
						"UniversalLinks": ""
					}
				}
			},
			"icons": {
				"android": {
					"hdpi": "static/icon-72.png",
					"xhdpi": "static/icon-96.png",
					"xxhdpi": "static/icon-144.png",
					"xxxhdpi": "static/icon-192.png"
				},
				"ios": {
					"appstore": "static/icon-1024.png",
					"iphone": {
						"app@2x": "static/icon-120.png",
						"app@3x": "static/icon-180.png",
						"spotlight@2x": "static/icon-80.png",
						"spotlight@3x": "static/icon-120.png",
						"settings@2x": "static/icon-58.png",
						"settings@3x": "static/icon-87.png",
						"notification@2x": "static/icon-40.png",
						"notification@3x": "static/icon-60.png"
					},
					"ipad": {
						"app": "static/icon-76.png",
						"app@2x": "static/icon-152.png",
						"propipad@2x": "static/icon-167.png",
						"spotlight": "static/icon-40.png",
						"spotlight@2x": "static/icon-80.png",
						"settings": "static/icon-29.png",
						"settings@2x": "static/icon-58.png",
						"notification": "static/icon-20.png",
						"notification@2x": "static/icon-40.png"
					}
				}
			},
			"splashscreen": {
				"android": {
					"hdpi": "static/splash-android-hdpi.png",
					"xhdpi": "static/splash-android-xhdpi.png",
					"xxhdpi": "static/splash-android-xxhdpi.png",
					"xxxhdpi": "static/splash-android-xxxhdpi.png"
				},
				"ios": {
					"storyboard": "static/splash-ios.storyboard",
					"iphone": {
						"portrait-896": "static/splash-iphone-x.png",
						"landscape-896": "static/splash-iphone-landscape-x.png"
					},
					"ipad": {
						"portrait-1668": "static/splash-ipad-portrait-1668.png",
						"landscape-1668": "static/splash-ipad-landscape-1668.png"
					}
				}
			}
		}
	},
	"quickapp": {},
	"mp-weixin": {
		"appid": "",
		"setting": {
			"urlCheck": false,
			"es6": true,
			"postcss": true,
			"minified": true
		},
		"usingComponents": true,
		"permission": {
			"scope.userLocation": {
				"desc": "你的位置信息将用于展示附近任务"
			}
		}
	},
	"mp-alipay": {
		"usingComponents": true,
		"permission": {
			"location": {
				"desc": "你的位置信息将用于展示附近任务"
			}
		}
	},
	"mp-baidu": {
		"usingComponents": true
	},
	"mp-toutiao": {
		"usingComponents": true
	},
	"mp-lark": {
		"usingComponents": true
	},
	"mp-qq": {
		"usingComponents": true
	},
	"mp-kuaishou": {
		"usingComponents": true
	},
	"h5": {
		"router": {
			"mode": "hash",
			"base": "./"
		},
		"devServer": {
			"port": 8080,
			"disableHostCheck": true,
			"proxy": {
				"/api": {
					"target": "http://localhost:8000",
					"changeOrigin": true,
					"secure": false
				}
			}
		},
		"title": "悬赏任务平台",
		"sdkConfigs": {
			"maps": {}
		}
	}
}
